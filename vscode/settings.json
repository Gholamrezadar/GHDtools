    // Token Color Customizations (GHD)
    "editor.tokenColorCustomizations": {
        "[Claude Theme]": {
            "textMateRules": [
                {
                    "scope": "keyword.operator, entity.name.function",
                    "settings": {
                        "foreground": "#61afef"
                    }
                },
                {
                    "scope": "storage.type, storage.modifier, keyword.control, keyword.other, entity.other.attribute-name.pragma.preprocessor.cpp",
                    "settings": {
                        "foreground": "#c678dd"
                    }
                },
                {
                    "scope": "variable.parameter, variable.other.property, variable, source, punctuation",
                    "settings": {
                        "foreground": "#abb2bf"
                    }
                },
                {
                    "scope": "constant, constant.numeric, entity.name.type.class, entity.name.type, entity.name.namespace",
                    "settings": {
                        "foreground": "#D19A66"
                    }
                },
                {
                    "scope": "punctuation.definition.directive.cpp",
                    "settings": {
                        "foreground": "#e06c75"
                    }
                },
                {
                    "scope": "comment, punctuation.definition.comment",
                    "settings": {
                        "foreground": "#5c6370",
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": "string",
                    "settings": {
                        "foreground": "#98C379"
                    }
                }
            ]
        },
        "[Tokyo Night]": {
            "textMateRules": [
                {
                    "scope": "entity.name.function",
                    "settings": {
                        "foreground": "#7AA2F7" // yellow-ish
                    }
                },
                {
                    "scope": [
                        "meta.body.function.definition.cpp",
                        "meta.function.definition.cpp",
                        "source.cpp"
                    ],
                    "settings": {
                        "foreground": "#7AA2F7" // yellow-ish
                    }
                },
                {
                    "scope": [
                        "storage.type",
                        "entity.name.type",
                        "support.type"
                    ],
                    "settings": {
                        "foreground": "#dfb260" // orange
                    }
                },
                {
                    "scope": ["entity.name.namespace"],
                    "settings": {
                        "foreground": "#dfb260" // orange
                    }
                },
                {
                    "scope": ["entity.name.function.preprocessor"],
                    "settings": {
                        "foreground": "#ff9e64" // white
                    }
                },
                {
                    "scope": [
                        "storage.type.modifier.access.control.private.cpp",
                        "storage.type.modifier.access.control.public.cpp",
                        "storage.type.class.cpp"
                    ],
                    "settings": {
                        "foreground": "#BB9AF7" // white
                    }
                },
                {
                    "scope": ["punctuation.definition.directive.cpp"],
                    "settings": {
                        "foreground": "#BB9AF7" // white
                    }
                },
                {
                    "scope": ["storage.type.struct.cpp"],
                    "settings": {
                        "foreground": "#BB9AF7" // white
                    }
                },
                {
                    "scope": ["punctuation.definition.string"],
                    "settings": {
                        "foreground": "#9ECE6A" // white
                    }
                },
                {
                    "scope": ["storage.source.cmake"],
                    "settings": {
                        "foreground": "#e9b555" // white
                    }
                }
            ]
        }
    },
