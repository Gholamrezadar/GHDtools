	"GHD DSU": {
		"prefix": "ghd_dsu",
		"body": [
			"struct DSU {",
			"    std::vector<int> parent, sizes;",
			"    ",
			"    DSU() {}",
			"    DSU(int n) {",
			"        init(n);",
			"    }",
			"    ",
			"    void init(int n) {",
			"        parent.resize(n);",
			"        std::iota(parent.begin(), parent.end(), 0);",
			"        sizes.assign(n, 1);",
			"    }",
			"    ",
			"    int find(int x) {",
			"        while (x != parent[x]) {",
			"            x = parent[x] = parent[parent[x]];",
			"        }",
			"        return x;",
			"    }",
			"    ",
			"    bool same(int x, int y) {",
			"        return find(x) == find(y);",
			"    }",
			"    ",
			"    bool merge(int x, int y) {",
			"        x = find(x);",
			"        y = find(y);",
			"        if (x == y) {",
			"            return false;",
			"        }",
			"        sizes[x] += sizes[y];",
			"        parent[y] = x;",
			"        return true;",
			"    }",
			"    ",
			"    int size(int x) {",
			"        return sizes[find(x)];",
			"    }",
			"};"
		],
		"description": "GHD DSU"
	}
