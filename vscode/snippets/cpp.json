	"divisors of n in O(sqrt(n))": {
		"prefix": "ghd_divisors",
		"body": [
			"// return the divisors of n in O(sqrt(n))",
			"vector<int> divisors(int n) {",
			"    vector<int> divs;",
			"    for (int i = 1; i * i <= n; i++) {",
			"        if (n % i == 0) {",
			"            divs.push_back(i);",
			"            if (i != n / i) divs.push_back(n / i);",
			"        }",
			"    }",
			"    return divs;",
			"}"
		],
		"description": "divisors of n in O(sqrt(n))"
	},
